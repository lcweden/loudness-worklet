{
  "name": "loudness-worklet",
  "version": "2.0.0",
  "description": "A lightweight and efficient AudioWorklet for real-time loudness measurement in the browser, compliant with the ITU-R BS.1770-5 standard.",
  "keywords": [
    "audio-worklet",
    "ebu-r128",
    "itu-r-bs1770",
    "loudness",
    "web-audio"
  ],
  "homepage": "https://lcweden.github.io/loudness-worklet/",
  "bugs": {
    "url": "https://github.com/lcweden/loudness-worklet/issues"
  },
  "license": "MIT",
  "author": "lcweden",
  "repository": {
    "type": "git",
    "url": "https://github.com/lcweden/loudness-worklet.git"
  },
  "workspaces": [
    "packages/*"
  ],
  "files": [
    "packages/lib/dist"
  ],
  "type": "module",
  "main": "./packages/lib/dist/index.js",
  "types": "./packages/lib/dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./packages/lib/dist/index.d.ts",
      "default": "./packages/lib/dist/index.js"
    }
  },
  "scripts": {
    "format": "vp fmt",
    "lint": "vp lint"
  },
  "devDependencies": {
    "@sveltejs/kit": "^2.70.0",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@types/audioworklet": "^0.0.100",
    "@types/node": "^26.0.1",
    "@typescript/native-preview": "^7.0.0-dev.20260627.2",
    "@voidzero-dev/vite-plus-core": "^0.2.5",
    "bumpp": "^11.1.0",
    "svelte": "^5.56.6",
    "svelte-check": "^4.6.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vite-plus": "^0.2.5"
  },
  "overrides": {
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vitest": "4.1.10"
  }
}
