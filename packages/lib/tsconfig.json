{
  "compilerOptions": {
    "target": "esnext",
    "module": "esnext",
    "lib": ["ESNext", "DOM", "DOM.Iterable", "WebWorker"],
    "moduleDetection": "force",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "types": ["vite-plus/client", "svelte", "audioworklet"],
    "strict": true,
    "noUnusedLocals": true,
    "declaration": true,
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "paths": {
      "#api/*": ["./src/api/*"],
      "#common/*": ["./src/common/*"],
      "#modules/*": ["./src/modules/*"],
      "#scripts/*": ["./src/scripts/*"],
      "#utils/*": ["./src/utils/*"]
    }
  },
  "include": ["src", "test", "web"]
}
