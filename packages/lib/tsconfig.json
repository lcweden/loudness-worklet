{
  "compilerOptions": {
    "target": "esnext",
    "lib": ["ESNext", "DOM", "DOM.Iterable", "WebWorker"],
    "moduleDetection": "force",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "types": ["node", "audioworklet"],
    "strict": true,
    "noUnusedLocals": true,
    "declaration": true,
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "skipLibCheck": true,
    "jsx": "preserve",
    "jsxImportSource": "solid-js",
    "paths": {
      "#common/*": ["./src/common/*"],
      "#modules/*": ["./src/modules/*"],
      "#scripts/*": ["./src/scripts/*"],
      "#utils/*": ["./src/utils/*"]
    }
  },
  "include": ["src", "test", "web", "vite-env.d.ts"]
}
